  private chromeChipBg(): string {
    return 'rgba(255,255,255,0.08)';
  }

  private connectionDotColor(): string {
    if (this.connected) { return '#34C759'; }
    if (this.connecting) { return this.accentColor; }
    return this.pal().danger;
