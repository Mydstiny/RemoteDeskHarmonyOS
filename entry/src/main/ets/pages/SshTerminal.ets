  // SSH з»Ҳз«Ҝе§Ӣз»Ҳж·ұиүІжЁЎејҸ вҖ” йЎ¶ж Ҹе’Ңеә•ж ҸдёҚи·ҹйҡҸзі»з»ҹдё»йўҳ, еӣәе®ҡж·ұиүІиғҢжҷҜ+дә®иүІж–Үеӯ—
  private chromeBg(): string {
    return '#11151C';
