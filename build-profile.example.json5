{
  "app": {
    "signingConfigs": [
      {
        "name": "default",
        "type": "HarmonyOS",
        "material": {
          "storeFile": "C:/path/to/debug.p12",
          "storePassword": "",
          "keyAlias": "Debug",
          "keyPassword": "",
          "signAlg": "SHA256withECDSA",
          "profile": "C:/path/to/debug.p7b",
          "certpath": "C:/path/to/debug.cer"
        }
      }
    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "targetSdkVersion": "6.1.0(23)",
        "compatibleSdkVersion": "6.1.0(23)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "strictMode": {
            "caseSensitiveCheck": true,
            "useNormalizedOHMUrl": true
          }
        }
      },
    ],
    "buildModeSet": [
      { "name": "debug" },
      { "name": "release" },
    ],
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        { "name": "default", "applyToProducts": ["default"] },
      ],
    },
  ],
}
